{
  "name": "lgsv_hr-system",
  "version": "1.0.0",
  "description": "LGSV_HR Management System with RBAC + JWT + MySQL",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed": "node database/seed-users.js",
    "migrate": "node -r dotenv/config node_modules/db-migrate/bin/db-migrate up --config database.json --env dev",
    "migrate:down": "node -r dotenv/config node_modules/db-migrate/bin/db-migrate down --config database.json --env dev",
    "migrate:roles": "node database/migrate-hr-manager-role.js",
    "migrate:attendance-biometric": "node database/migrate-biometric-attendance.js",
    "migrate:onboarding": "node database/migrate-onboarding-lifecycle.js",
    "migrate:lifecycle": "node database/migrate-employee-lifecycle-routing.js",
    "migrate:weekly-payroll": "node database/migrate-multi-pay-type-weekly-payroll.js up",
    "backfill:strict-encryption": "node scripts/backfill-strict-at-rest-encryption.js",
    "test:attendance-biometric": "node test-biometric-attendance.js",
    "test:attendance-policy": "node tests/attendance-policy.test.js",
    "test:payroll-attendance-config": "node tests/payroll-attendance-config.test.js",
    "test:security": "node tests/frontend-output-security.test.js && node tests/input-validation.test.js && node tests/upload-security.test.js && node tests/csrf-protection.test.js && node tests/payroll-piece-rate-auth.test.js && node tests/password-storage-security.test.js",
    "security:invalidate-legacy-passwords": "node scripts/invalidate-legacy-password-hashes.js --apply",
    "security:configure-local-db": "node scripts/configure-local-database-security.js --apply",
    "security:verify-db": "node scripts/verify-database-security.js",
    "test:payroll-statutory-controlled": "node scripts/payroll-statutory-controlled-test.js",
    "seed:payroll-daily-hourly-source": "node scripts/seed-payroll-daily-hourly-source.js",
    "test:onboarding": "node test-onboarding.js",
    "test:mfa": "node tests/iprog-sms-service.test.js",
    "test:payroll-controlled": "node scripts/payroll-controlled-test.js",
    "seed:payroll-manual-deduction": "node scripts/payroll-manual-deduction-seed.js",
    "seed:payroll-deduction-boundary": "node scripts/payroll-deduction-boundary-seed.js",
    "seed:payroll-piece-trip-deduction": "node scripts/payroll-piece-trip-deduction-seed.js",
    "seed:payroll-june-trueup-source": "node scripts/payroll-june-5week-trueup-test.js --source-only",
    "seed:biometric-survey": "node scripts/seed-biometric-survey-employees.js",
    "seed:attendance-0813": "node scripts/seed-attendance-0813-sample.js",
    "test:biometric-survey-scans": "node scripts/simulate-biometric-survey-scans.js --reset",
    "test:payroll-june-trueup": "node scripts/payroll-june-5week-trueup-test.js"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.4",
    "@hyperledger/fabric-gateway": "^1.11.0",
    "argon2": "^0.44.0",
    "db-migrate": "^0.11.14",
    "db-migrate-mysql": "^3.0.0",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "mysql2": "^3.9.7",
    "pdfkit": "^0.19.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
