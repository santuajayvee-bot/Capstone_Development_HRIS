# Local server
PORT=3000
NODE_ENV=development
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=8h
# Account lockout policy. The lock applies immediately on the threshold failure.
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15

# Privileged-role MFA. TOTP uses Google Authenticator, Microsoft Authenticator,
# Authy, Bitwarden, or any RFC 6238-compatible authenticator app.
MFA_ENABLED=true
MFA_REQUIRE_ALL_USERS=false
MFA_CHALLENGE_TTL_SECONDS=300
MFA_TOTP_WINDOW_STEPS=1
MFA_TOTP_ISSUER=LGSV HR

# Google reCAPTCHA v2 checkbox. Production login fails closed if enabled but
# these keys or the allowed hostname are missing.
RECAPTCHA_ENABLED=true
RECAPTCHA_SITE_KEY=replace-with-google-recaptcha-site-key
RECAPTCHA_SECRET_KEY=replace-with-google-recaptcha-secret-key
RECAPTCHA_ALLOWED_HOSTNAMES=localhost,lgsvhr.com
RECAPTCHA_VERIFY_TIMEOUT_MS=5000

AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=300

# System Health diagnostics. Keep concurrency modest for AWS RDS MySQL so a
# full health check does not flood the database connection pool.
SYSTEM_HEALTH_MODULE_TIMEOUT_MS=5000
SYSTEM_HEALTH_SLOW_WARNING_MS=3000
SYSTEM_HEALTH_CHECK_CONCURRENCY=4
SYSTEM_HEALTH_AUTO_CHECK_ENABLED=false
SYSTEM_HEALTH_INTERVAL_MINUTES=10

# Backup and recovery execution. Local artifacts are always AES-256-GCM
# encrypted; production must configure either S3/RDS or a private local root.
BACKUP_STEP_UP_TTL_SECONDS=300
BACKUP_WORKER_LEASE_MINUTES=120
BACKUP_RECOVERY_REAPER_ENABLED=true
BACKUP_RECOVERY_REAPER_INTERVAL_MS=300000
BACKUP_ENCRYPTION_KEY=
BACKUP_LOCAL_ROOT=
BACKUP_WORK_ROOT=
BACKUP_TOOL_WORK_ROOT=
BACKUP_RESTORE_OUTPUT_ROOT=
BACKUP_FILE_SOURCE_PATHS=
BACKUP_CONFIG_SOURCE_PATHS=
BACKUP_CAPTURE_ROW_COUNTS=true
BACKUP_CAPTURE_INTEGRITY=true
BACKUP_INCLUDE_ROUTINES=false
BACKUP_INCLUDE_EVENTS=false
BACKUP_MAX_FILES=25000
BACKUP_MAX_BYTES=5368709120
BACKUP_MAX_DUMP_BYTES=5368709120
BACKUP_TOOL_TIMEOUT_MS=1800000

# MySQL client binaries. Use absolute paths when they are not on PATH.
MYSQLDUMP_PATH=mysqldump
MYSQL_PATH=mysql

# Optional dedicated read-only backup account. Unset values fall back to DB_*.
# Enable BACKUP_INCLUDE_ROUTINES/EVENTS only when this account has those grants.
BACKUP_SOURCE_DB_HOST=
BACKUP_SOURCE_DB_PORT=3306
BACKUP_SOURCE_DB_USER=
BACKUP_SOURCE_DB_PASSWORD=
BACKUP_SOURCE_DB_NAME=
BACKUP_SOURCE_DB_SSL=

# Dedicated isolated restore-test connection. In production this should point
# to a separate MySQL/RDS host with permission to create/drop scratch schemas.
BACKUP_DRY_RUN_DB_HOST=
BACKUP_DRY_RUN_DB_PORT=3306
BACKUP_DRY_RUN_DB_USER=
BACKUP_DRY_RUN_DB_PASSWORD=
BACKUP_DRY_RUN_DB_NAME=
BACKUP_DRY_RUN_DB_SSL=true
BACKUP_ALLOW_SAME_SERVER_DRY_RUN=false

# Live restore remains fail-closed until an explicit, empty recovery target is
# configured. Never target DB_NAME unless an audited in-place restore is intended.
BACKUP_LIVE_RESTORE_ENABLED=false
BACKUP_RESTORE_DB_HOST=
BACKUP_RESTORE_DB_PORT=3306
BACKUP_RESTORE_DB_USER=
BACKUP_RESTORE_DB_PASSWORD=
BACKUP_RESTORE_DB_NAME=
BACKUP_RESTORE_DB_SSL=true
BACKUP_ALLOW_IN_PLACE_RESTORE=false

# Amazon S3 artifact and RDS snapshot adapters.
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=
AWS_S3_BACKUP_PREFIX=lgsv-hr/backups
AWS_S3_KMS_KEY_ID=
AWS_RDS_DB_INSTANCE_IDENTIFIER=
AWS_RDS_SNAPSHOT_WAIT_SECONDS=1800
AWS_RDS_RESTORE_INSTANCE_CLASS=
AWS_RDS_RESTORE_SUBNET_GROUP=
AWS_RDS_RESTORE_SECURITY_GROUP_IDS=
AWS_RDS_RESTORE_WAIT_FOR_AVAILABLE=true

# Read-only credentials used after an isolated RDS snapshot restore becomes
# available. The runtime discovers the restored instance endpoint server-side.
BACKUP_RDS_VERIFY_DB_PORT=3306
BACKUP_RDS_VERIFY_DB_USER=
BACKUP_RDS_VERIFY_DB_PASSWORD=
BACKUP_RDS_VERIFY_DB_NAME=
BACKUP_RDS_VERIFY_DB_SSL=true

AES_ENCRYPTION_KEY=replace-with-64-hex-characters
AES_256_SECRET_KEY=
# Optional: if blank, employee onboarding hashes a random temporary password.
DEFAULT_EMPLOYEE_TEMP_PASSWORD=

# Public HTTPS origin used for QR links and mobile browser features.
# Example: APP_PUBLIC_URL=https://your-domain.com
# For local phone GPS testing, use an HTTPS tunnel URL here.
# In AWS production, set this to the HTTPS ALB/CloudFront/custom-domain origin
# used by biometric stations and browser clients.
APP_PUBLIC_URL=
# Optional comma-separated extra trusted browser origins. Keep empty unless
# the same application is intentionally served from more than one HTTPS origin.
CSRF_ALLOWED_ORIGINS=

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=lgsv_app
DB_PASSWORD=replace-with-a-long-random-database-password
DB_NAME=lgsv_hr_db
# Separate DDL account used only by db-migrate. Never use this for app runtime.
MIGRATION_DB_USER=lgsv_migrator
MIGRATION_DB_PASSWORD=replace-with-a-separate-long-random-password

# Enable for deployed MySQL connections
DB_SSL=true
DB_SSL_CA_PATH=
DB_SSL_CERT_PATH=
DB_SSL_KEY_PATH=
DB_SSL_REJECT_UNAUTHORIZED=true

# Enable when Node terminates TLS directly.
# If a trusted reverse proxy terminates TLS 1.3, leave these empty.
TLS_CERT_PATH=
TLS_KEY_PATH=
TLS_CA_PATH=
# Set true only after HTTPS/TLS 1.3 is terminated at the AWS load balancer or
# reverse proxy and traffic to Node stays on the private application network.
AWS_TLS_TERMINATED_AT_LOAD_BALANCER=false

# Biometric vendor mTLS client certificate, when required for outbound pull sync.
BIOMETRIC_MTLS_CERT_PATH=
BIOMETRIC_MTLS_KEY_PATH=
BIOMETRIC_CA_PATH=
# AWS biometric station setup:
# - Register the device in System Administration / Attendance Sync.
# - Use API_KEY, HMAC, BEARER, OAUTH2, or MTLS. Do not use NONE in production.
# - Put the same API key in C:\ProgramData\LGSV_HR\ZK9500Bridge\bridge-config.json
#   as auth_secret, and point hris_attendance_url to:
#   https://your-aws-domain.com/api/biometric/station-attendance

# Permissioned blockchain adapter for onboarding/attendance anchor adapters
BLOCKCHAIN_API_URL=
BLOCKCHAIN_API_TOKEN=
BLOCKCHAIN_MTLS_CERT_PATH=
BLOCKCHAIN_MTLS_KEY_PATH=
BLOCKCHAIN_CA_PATH=

# Hyperledger Fabric payroll audit ledger
# Leave FABRIC_ENABLED=false for local development without a running Fabric network.
FABRIC_ENABLED=false
FABRIC_CHANNEL_NAME=lgsvhr-payroll-channel
FABRIC_CHAINCODE_NAME=payroll-audit
FABRIC_MSP_ID=PayrollMSP
FABRIC_PEER_ENDPOINT=localhost:7051
FABRIC_PEER_HOST_ALIAS=peer0.payroll.lgsvhr.com
FABRIC_TLS_CERT_PATH=./fabric-network/organizations/peerOrganizations/payroll.lgsvhr.com/peers/peer0.payroll.lgsvhr.com/tls/ca.crt
FABRIC_CERT_PATH=./fabric-network/organizations/peerOrganizations/payroll.lgsvhr.com/users/User1@payroll.lgsvhr.com/msp/signcerts/User1@payroll.lgsvhr.com-cert.pem
FABRIC_KEY_DIRECTORY_PATH=./fabric-network/organizations/peerOrganizations/payroll.lgsvhr.com/users/User1@payroll.lgsvhr.com/msp/keystore
BLOCKCHAIN_EMPLOYEE_REF_PEPPER=replace-with-a-long-random-pepper

# Development-only escape hatches. Never enable in production.
ALLOW_INSECURE_BIOMETRIC_API=false
ALLOW_UNAUTHENTICATED_BIOMETRIC_WEBHOOK=false
DISABLE_GEOFENCE=false
